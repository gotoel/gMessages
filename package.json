{
  "name": "gmessages",
  "version": "1.0.0",
  "description": "Desktop wrapper for Google Messages",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "start:safe": "electron . --disable-gpu",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "lint": "eslint src ui"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "gotoel",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "globals": "^16.5.0"
  },
  "build": {
    "appId": "com.gotoel.gmessages",
    "productName": "gMessages",
    "directories": {
      "output": ".electron-dist"
    },
    "files": [
      "src/**/*",
      "ui/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
