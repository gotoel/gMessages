{
  "name": "gmessages",
  "version": "1.0.0",
  "description": "Desktop wrapper for Google Messages",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "start:safe": "electron . --disable-gpu",
    "build": "npm run icons && electron-builder --publish never",
    "build:win": "npm run icons && electron-builder --win --publish never",
    "build:mac": "npm run icons && electron-builder --mac --publish never",
    "build:linux": "npm run icons && electron-builder --linux --publish never",
    "build:dir": "npm run icons && electron-builder --dir --publish never",
    "build:dir:win": "npm run icons && electron-builder --win --dir --publish never",
    "build:dir:mac": "npm run icons && electron-builder --mac --dir --publish never",
    "build:dir:linux": "npm run icons && electron-builder --linux --dir --publish never",
    "icons": "node scripts/generate-icons.mjs",
    "lint": "eslint src ui"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "gotoel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gotoel/gMessages.git"
  },
  "homepage": "https://github.com/gotoel/gMessages#readme",
  "bugs": {
    "url": "https://github.com/gotoel/gMessages/issues"
  },
  "keywords": [
    "google-messages",
    "electron",
    "desktop",
    "sms",
    "rcs"
  ],
  "dependencies": {
    "electron-store": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "com.gotoel.gmessages",
    "productName": "gMessages",
    "publish": null,
    "directories": {
      "output": ".electron-dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "ui/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "executableName": "gMessages",
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "gMessages",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.social-networking",
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "gMessages"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Network",
      "maintainer": "gotoel",
      "synopsis": "Desktop wrapper for Google Messages"
    }
  }
}
